@using Microsoft.AspNetCore.Identity;
@inject SignInManager<Users> signInManager;

<ul class="navbar-nav ms-auto">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="nav-item d-flex align-items-center">
            <a class="btn btn-danger btn-sm px-4" asp-controller="Account" asp-action="Logout">Logout</a>
        </li>
    }
    else
    {
        <li class="nav-item d-flex align-items-center me-2">
            <a class="btn btn-success btn-sm px-4" asp-controller="Account" asp-action="Login">Login</a>
        </li>
        <li class="nav-item d-flex align-items-center">
            <a class="btn btn-primary btn-sm px-4" asp-controller="Account" asp-action="Register">Register</a>
        </li>
    }

</ul>

